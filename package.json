{
  "name": "poc-step-function-calculator",
  "version": "2.0.0",
  "private": true,
  "description": "Build tooling for the multi-runtime Step Functions calculator demo.",
  "scripts": {
    "build:lambdas": "./scripts/build_lambdas.sh",
    "terraform:fmt": "terraform -chdir=terraform fmt -recursive",
    "terraform:init": "terraform -chdir=terraform init -upgrade",
    "terraform:validate": "terraform -chdir=terraform validate -no-color"
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "3.1009.0",
    "@aws-sdk/client-sfn": "3.1009.0",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.5.0",
    "typescript": "5.9.3"
  }
}
